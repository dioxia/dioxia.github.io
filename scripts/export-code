#!/usr/bin/env bash

set -euo pipefail

OUTPUT="chatgpt-code.txt"

# Start with an empty file.
: > "$OUTPUT"

find . \
  -type d \( \
    -name node_modules -o \
    -name .git -o \
    -name dist -o \
    -name build -o \
    -name coverage -o \
    -name .cache -o \
    -name .next -o \
    -name out -o \
    -name vendor \
  \) -prune -o \
  -type f \( \
    -iname "*.js" -o \
    -iname "*.css" \
  \) -print0 |
sort -z |
while IFS= read -r -d '' file; do
    {
        echo "================================================================"
        echo "FILE: ${file#./}"
        echo "================================================================"
        echo
        cat "$file"
        echo
        echo
    } >> "$OUTPUT"
done

echo "Done!"
echo "Output written to: $(pwd)/$OUTPUT"


